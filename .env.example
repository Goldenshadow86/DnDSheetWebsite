# Database (MySQL — use with phpMyAdmin)
# Create a database in phpMyAdmin, then set URL (replace user, password, host, dbname):
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"

# Discord OAuth - create app at https://discord.com/developers/applications
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"
